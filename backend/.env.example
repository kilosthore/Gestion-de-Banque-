
# Copier ce fichier en ".env" et remplir les valeurs

# Base de données MySQL (la base est créée automatiquement au démarrage)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=banque
DB_NAME_TEST=banque_test
DB_USER=root
DB_PASS=

# Sécurité JWT (mettre une longue chaîne aléatoire)
JWT_SECRET=changez_moi_par_une_longue_chaine_aleatoire_64_caracteres_minimum
JWT_EXPIRES=30m
TEMP_TOKEN_EXPIRES=5m

# Serveur
PORT=5000
CLIENT_URL=http://localhost:5173

# Email pour l'envoi du code OTP (optionnel — si vide, mode démo activé)
# Gmail : créer un "mot de passe d'application" sur https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# true = le code OTP est aussi renvoyé dans la réponse API (pour la démo / présentation)
DEMO_OTP=true
